{
    "name": "kntnt/kntnt-ai-visibility",
    "description": "WordPress plugin that makes content-rich websites discoverable, visible and readable by AI agents.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Kntnt",
            "email": "thomas@kntnt.com",
            "homepage": "https://www.kntnt.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "kntnt/html-to-markdown": "^0.1.1"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "dg/bypass-finals": "^1.7",
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Kntnt\\Ai_Visibility\\": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "tests/Helpers/WpStubs.php",
            "tests/Helpers/TestSupport.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "test": "pest --testsuite=Unit",
        "stan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
        "phpcs": "phpcs --standard=phpcs.xml.dist",
        "phpcbf": "phpcbf --standard=phpcs.xml.dist",
        "build": "bash build-release-zip.sh --output ."
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
