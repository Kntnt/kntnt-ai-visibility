# Dependencies — restored by `composer install`; the release zip ships its own
# production vendor/ built by build-release-zip.sh.
/vendor/
/node_modules/

# Test and tooling caches.
/.phpunit.cache/
.phpunit.result.cache
/coverage/
*.log

# Release artefact emitted by ./build-release-zip.sh — uploaded to the GitHub
# release as an asset, not committed. dist/ is the default output directory.
/kntnt-ai-visibility.zip
/dist/

# Local test-environment overrides.
.env
.env.testing

# Editor / OS files.
.DS_Store
.idea/
.vscode/
*.swp
*~

# Advisor revision material (improve-skill plans) and Claude Code local/worktree
# state — kept on disk, deliberately not committed.
/plans/
/.claude/

# Composer and npm lock files are committed (kept), so they are NOT ignored.
